# CORS origins (comma-separated — for production, set via Cloudflare dashboard or GitHub Secrets)
ALLOWED_ORIGINS=http://localhost:8787,http://localhost:3000,http://localhost:5173,http://localhost:8080

# Integration test secret (must match staging env var in GitHub Secrets)
# Required to run integration tests against staging
INTEGRATION_TEST_SECRET=your-secret-here

# VPS / standalone server (optional — only used by npm run serve)
# PORT=3000
# DB_PATH=./data/likes.db
