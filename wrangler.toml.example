# Example wrangler.toml — copy to wrangler.toml and fill in your IDs
name = "simplelikes"
main = "src/index.ts"
compatibility_date = "2025-01-01"

[[d1_databases]]
binding = "DB"
database_name = "simplelikes"
database_id = "<your-d1-database-id>"

# Environment: staging (deployed on push to main)
[env.staging]
name = "simplelikes-staging"
[[env.staging.d1_databases]]
binding = "DB"
database_name = "simplelikes-staging"
database_id = "<your-staging-database-id>"

# Environment: production (deployed on tag)
[env.production]
name = "simplelikes"
[[env.production.d1_databases]]
binding = "DB"
database_name = "simplelikes"
database_id = "<your-production-database-id>"

# To create the D1 databases:
#   wrangler d1 create simplelikes
#   wrangler d1 create simplelikes-staging
# Then copy the database_ids from the output.
