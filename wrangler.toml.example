# Copy to wrangler.toml (gitignored) and replace placeholders with real IDs
name = "simplelikes"
main = "src/index.ts"
compatibility_date = "2025-01-01"

[[d1_databases]]
binding = "DB"
database_name = "simplelikes"
database_id = "00000000-0000-0000-0000-000000000000"

[env.staging]
name = "simplelikes-staging"
[[env.staging.d1_databases]]
binding = "DB"
database_name = "simplelikes-staging"
database_id = "__STAGING_DATABASE_ID__"

[env.production]
name = "simplelikes"
[[env.production.d1_databases]]
binding = "DB"
database_name = "simplelikes"
database_id = "__PRODUCTION_DATABASE_ID__"
